# Cloudflare R2 credentials for local development image uploads.
# Copy this file to .env (project root) and fill in your values.
# When these are set, the React dev server will automatically upload
# any newly fetched card images to the specified R2 bucket.

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
